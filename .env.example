# Copy to backend/.env and frontend/.env, then fill in real values.
# Do NOT commit real values — .env files are gitignored.

# ─── Backend (backend/.env) ─────────────────────────────
PORT=4000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace_with_strong_random_secret
JWT_TTL=7d

RESEND_API_KEY=re_xxx
RESEND_DOMAIN=app.example.com
RESEND_FROM="Brand <noreply@app.example.com>"

ADMIN_EMAIL=admin@example.com
WHATSAPP_PHONE=000000000000

LOCATION_SNACKS=
LOCATION_SUPREME=
LOCATION_SWAN=
LOCATION_ZURI=

PUBLIC_BASE_URL=http://localhost:4000
# Optional — fill in to route uploads through Cloudinary instead of local FS:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Frontend (frontend/.env) ───────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_ADMIN_EMAIL=admin@example.com
VITE_WHATSAPP_PHONE=000000000000
